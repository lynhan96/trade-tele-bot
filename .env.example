# ═══════════════════════════════════════════════════════════════════════════
# Binance Telegram Trading Bot - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─── Core Services ───────────────────────────────────────────────────────────

# Telegram Bot Token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Redis Configuration (for caching and session data)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB URI (required for AI signal queue persistence and historical data)
MONGODB_URI=mongodb://localhost:27017/binance-tele-bot

# Logging Level (debug | info | warn | error)
LOG_LEVEL=info

# ─── AI Signal System ────────────────────────────────────────────────────────

# Enable/Disable AI-powered trading signals
# Set to false to use manual trading only
AI_ENABLED=true

# Test mode — generates signals without placing real trades
# Recommended: true for initial setup and testing
AI_TEST_MODE=false

# ─── Anthropic API Configuration ─────────────────────────────────────────────

# Anthropic API Key (required for AI parameter tuning)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Rate Limits (to control API costs)
# Haiku: Fast, cheap model for parameter tuning ($0.25/MTok input, $1.25/MTok output)
# Sonnet: Advanced model for regime analysis ($3/MTok input, $15/MTok output)
AI_MAX_HAIKU_PER_HOUR=30        # ~720/day = $3-5/month (recommended: 20-40)
AI_MAX_SONNET_PER_HOUR=2        # ~48/day = $2-4/month (recommended: 1-3)

# ─── Binance API Configuration ───────────────────────────────────────────────

# Monitor Account Credentials (used to detect when positions close)
# IMPORTANT: This should be a Binance account that:
# 1. Has read-only or trading permissions
# 2. Trades with BOT_FUTURE_AI_1 bot configuration
# 3. All bot users' positions are monitored through this account
AI_MONITOR_BINANCE_API_KEY=your_binance_api_key
AI_MONITOR_BINANCE_API_SECRET=your_binance_api_secret

# ─── Admin Access Control ────────────────────────────────────────────────────

# Admin Telegram User IDs (comma-separated, no spaces)
# Example: AI_ADMIN_TELEGRAM_ID=123456789,987654321
# Leave empty to allow ALL users to use /ai admin commands (single-user bots)
AI_ADMIN_TELEGRAM_ID=

# ─── Coin Filter Configuration ───────────────────────────────────────────────
# These settings determine which coins are eligible for AI signal generation

# Minimum 24h trading volume in USD
# Lower = more coins but potentially less liquid
# Higher = fewer coins but more stable/liquid markets
# Recommended: 30M-100M for balanced approach
AI_MIN_COIN_VOLUME_USD=50000000

# Minimum absolute price change percentage in 24h
# Filters out stagnant coins with no momentum
# Recommended: 1.0-2.0 for active markets, 0.5-1.0 for ranging markets
AI_MIN_PRICE_CHANGE_PCT=1.0

# Maximum number of coins to monitor simultaneously
# More coins = more signals but higher API costs and complexity
# Fewer coins = focused analysis on best opportunities
# Recommended: 8-15 coins for optimal performance
AI_MAX_SHORTLIST_SIZE=10

# ─── Signal Queue Configuration ──────────────────────────────────────────────

# How long QUEUED signals remain valid (in hours)
# Note: Actual TTL varies by timeframe profile:
# - INTRADAY (15m): Active=8h, Queued=4h
# - SWING (4h): Active=72h, Queued=48h
# This setting is documented but timeframe-specific TTLs are hardcoded
AI_SIGNAL_TTL_HOURS=4

