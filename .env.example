# ═══════════════════════════════════════════════════════════════════════════
# Binance Telegram Trading Bot - Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════

# ─── Core Services ───────────────────────────────────────────────────────────

# Telegram Bot Token from @BotFather (https://t.me/BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Redis Configuration (for caching and session data)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# MongoDB URI (required for AI signal queue persistence and historical data)
MONGODB_URI=mongodb://localhost:27017/binance-tele-bot

# Logging Level (debug | info | warn | error)
LOG_LEVEL=info

# ─── AI Signal System ────────────────────────────────────────────────────────

# Enable/Disable AI-powered trading signals
# Set to false to use manual trading only
AI_ENABLED=true

# Test mode — generates signals without placing real trades
# Recommended: true for initial setup and testing
AI_TEST_MODE=false

# ─── Anthropic API Configuration ─────────────────────────────────────────────

# Anthropic API Key (required for AI parameter tuning)
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Rate Limits (to control API costs)
# Waterfall: Haiku (primary, 10/scan) → GPT-4o-mini (fallback) → static ATR defaults
# Haiku 4.5: $0.80/MTok in + $4/MTok out ≈ ~$0.001/call; params cached 4h
# At 100 coins / 4h TTL = ~25 calls/hour steady-state → ~$0.025/hour
# NOTE: Sonnet has been removed from tuning waterfall (overkill for structured JSON params)
AI_MAX_HAIKU_PER_HOUR=30

# ─── OpenAI GPT Fallback ──────────────────────────────────────────────────────
# GPT-4o-mini is used when Haiku hits hourly limit — very cheap fallback
# Leave blank to disable (will use static ATR defaults instead)
OPENAI_API_KEY=
AI_MAX_GPT_PER_HOUR=30

# ─── Binance API Configuration ───────────────────────────────────────────────

# Monitor Account Credentials (used to detect when positions close)
# IMPORTANT: This should be a Binance account that:
# 1. Has read-only or trading permissions
# 2. Trades with BOT_FUTURE_AI_1 bot configuration
# 3. All bot users' positions are monitored through this account
AI_MONITOR_BINANCE_API_KEY=your_binance_api_key
AI_MONITOR_BINANCE_API_SECRET=your_binance_api_secret

# ─── Admin Access Control ────────────────────────────────────────────────────

# Admin Telegram User IDs (comma-separated, no spaces)
# Example: AI_ADMIN_TELEGRAM_ID=123456789,987654321
# Leave empty to allow ALL users to use /ai admin commands (single-user bots)
AI_ADMIN_TELEGRAM_ID=

# ─── Coin Filter Configuration ───────────────────────────────────────────────
# These settings determine which coins are eligible for AI signal generation
# NOTE: AI (Haiku) auto-tunes these values every 8h based on regime and caches in Redis.
#       .env values are the MINIMUM FLOOR — AI can go higher but never below these.

# Minimum 24h trading volume in USD
# Lower = more coins but potentially less liquid
# Recommended: 10M-50M for balanced approach; AI will adjust per regime
AI_MIN_COIN_VOLUME_USD=10000000

# Minimum absolute price change percentage in 24h
# Filters stagnant coins; AI adjusts per regime (VOLATILE = 0.3%, SIDEWAYS = 0.5%)
AI_MIN_PRICE_CHANGE_PCT=0.3

# Maximum number of coins to monitor simultaneously
# This is the MINIMUM FLOOR — AI can pick a higher number but never below this value
# Recommended: 50-100; more coins = more signals but more API calls
AI_MAX_SHORTLIST_SIZE=100

# ─── Signal Queue Configuration ──────────────────────────────────────────────

# Timeframe profile: ALL coins now use SWING (4h primary, 1d HTF)
# BTC and ETH additionally get INTRADAY (15m) analysis
# SWING signals: Active=72h, Queued=48h, SL 1.5-4%, TP 3-4x SL
AI_SIGNAL_TTL_HOURS=48

# ─── Feature Toggles ───────────────────────────────────────────────────────

# Fibonacci-enhanced TP/SL: uses swing high/low Fibonacci levels for dynamic TP targets
# Set to false to use static ATR-based TP only
ENABLE_FIBONACCI=true

# SMC Fair Value Gap strategy: detects FVG zones + Order Blocks for entry signals
# New strategy added to pipe-delimited selection in RANGE_BOUND/SIDEWAYS/MIXED regimes
ENABLE_SMC_FVG=true

# BOS/CHoCH regime refinement: Break of Structure / Change of Character on BTC 4h
# CHoCH can soften extreme regimes (STRONG_BULL→MIXED, STRONG_BEAR→MIXED)
# BOS confirms existing trend (boosts confidence +5)
ENABLE_BOS_CHOCH=true

# ─── CoinGecko Integration (Social Momentum Scoring) ──────────────────────

# CoinGecko API key — get free Demo key at https://www.coingecko.com/en/api
# When set, trending coins get a 15% weight boost in coin filter scoring
# Leave empty to disable CoinGecko integration entirely
COINGECKO_API_KEY=

# Set to true if using a paid CoinGecko plan (Analyst/Lite/Pro)
# Paid plans use pro-api.coingecko.com with x-cg-pro-api-key header
COINGECKO_PAID=false

# Rate limit per minute (free Demo = 30, paid = 500)
COINGECKO_RATE_LIMIT=25

