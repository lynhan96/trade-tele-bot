# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=8443358580:AAHJ3uIw1snHW3rDKPlET8qup91IAggoZUU

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# TCP Microservice (receives signals from bot-signal service)
TCP_HOST=127.0.0.1
TCP_PORT=8010

# ─── AI Signal System ────────────────────────────────────────────────────────

# MongoDB (required for AI signal queue persistence)
MONGODB_URI=mongodb://localhost:27017/binance-tele-bot

# Anthropic API (required for AI parameter tuning)
ANTHROPIC_API_KEY=sk-ant-api03-...
AI_ENABLED=true

# Monitor account Binance credentials (used to detect position closes)
# This should be a Binance account that trades with BOT_FUTURE_AI_1
AI_MONITOR_BINANCE_API_KEY=
AI_MONITOR_BINANCE_API_SECRET=

# Test mode — set to true to generate signals without placing real trades
AI_TEST_MODE=false

# Admin Telegram IDs (comma-separated) — only these users can use /ai admin commands
# Leave empty to allow all users to use admin commands (for single-user bots)
AI_ADMIN_TELEGRAM_ID=

# Signal configuration
AI_SIGNAL_TTL_HOURS=4           # How long QUEUED signals remain valid
AI_MAX_HAIKU_PER_HOUR=30        # Max Haiku API calls per hour
AI_MAX_SONNET_PER_HOUR=2        # Max Sonnet API calls per hour

# Coin filter configuration
AI_MIN_COIN_VOLUME_USD=50000000 # Minimum 24h volume in USD to qualify
AI_MIN_PRICE_CHANGE_PCT=1.0     # Minimum absolute price change %
AI_MAX_SHORTLIST_SIZE=10        # Maximum coins to monitor simultaneously

