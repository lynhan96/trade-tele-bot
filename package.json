{
  "name": "binance-tele-bot",
  "version": "1.0.0",
  "description": "NestJS Telegram bot for Binance trading with Redis storage",
  "main": "dist/main.js",
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch 2>&1 | tee /tmp/bot.log",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "test:safety": "npx ts-node run-simulator.ts",
    "test:complete": "npx ts-node run-complete-simulator.ts",
    "test:skills": "npx ts-node run-skills-simulator.ts",
    "test:all": "npx ts-node run-all-simulators.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.36.3",
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/microservices": "^10.3.0",
    "@nestjs/mongoose": "^10.0.6",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/platform-socket.io": "^11.1.16",
    "@nestjs/schedule": "^4.0.0",
    "@nestjs/websockets": "^11.1.16",
    "axios": "^1.13.4",
    "bcryptjs": "^3.0.3",
    "binance-api-node": "^0.12.5",
    "https-proxy-agent": "^7.0.6",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^8.9.5",
    "node-telegram-bot-api": "^0.65.1",
    "openai": "^6.25.0",
    "redis": "^4.6.12",
    "reflect-metadata": "^0.2.1",
    "rxjs": "^7.8.1",
    "socket.io": "^4.8.3",
    "technicalindicators": "^3.1.0",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.11.0",
    "@types/node-telegram-bot-api": "^0.64.5",
    "@types/ws": "^8.18.1",
    "prettier": "^3.2.4",
    "typescript": "^5.3.3"
  }
}
